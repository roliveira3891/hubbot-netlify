# Copie este arquivo para .env.local e preencha os valores.

# URL pública do site (usada em SEO/sitemap). Default: https://hubbot.io
NEXT_PUBLIC_SITE_URL="https://hubbot.io"

# Sanity — blog (painel em /studio)
NEXT_PUBLIC_SANITY_PROJECT_ID="seu-project-id"
NEXT_PUBLIC_SANITY_DATASET="production"
# Token de servidor (preview/rascunhos). Conteúdo publicado é lido sem token.
SANITY_API_READ_TOKEN="seu-token-de-leitura"

# Resend — envio do formulário de contato (/api/send-email)
RESEND_API_KEY="re_sua_chave"
